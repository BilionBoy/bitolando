<!DOCTYPE html>
<html lang="pt-BR" data-theme="light">
  <head>
    <title>bitolando · admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" type="image/x-icon"    href="/layout/assets/img/favicon_io/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/layout/assets/img/favicon_io/favicon-32x32.png">
    <link rel="apple-touch-icon" href="/layout/assets/img/favicon_io/apple-touch-icon.png">
    <meta name="theme-color" content="#FAFAF8">
    <%= render "shared/theme_bootstrap" %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmE2E+J3A0Ys4phNrxzqEkGdFdN" crossorigin="anonymous"></script>
  </head>
  <body>
    <div class="bito">
      <header class="bito-header">
        <div class="bito-logo">
          <%= link_to admin_root_path, style: "color:inherit;text-decoration:none;" do %>
            bitolando<span class="scope">admin</span>
          <% end %>
        </div>
        <nav class="bito-meta-nav">
          <%= link_to "posts", admin_posts_path, class: (controller_name == "posts" ? "active" : nil) %>
          <span class="sep">·</span>
          <%= link_to "imagens", admin_imagens_path, class: (controller_name == "imagens" ? "active" : nil) %>
          <span class="sep">·</span>
          <%= link_to "categorias", admin_categorias_path, class: (controller_name == "categorias" ? "active" : nil) %>
          <span class="sep">·</span>
          <%= link_to "ver site", root_path, target: "_blank" %>
          <span class="sep">·</span>
          <button class="bito-theme-toggle" type="button" data-bito-theme-toggle onclick="bitoToggleTheme()" title="usar tema escuro" aria-label="alternar tema claro/escuro" aria-pressed="false">◐</button>
          <span class="sep">·</span>
          <%= link_to "sair", destroy_usuario_session_path, data: { turbo_method: :delete } %>
        </nav>
      </header>

      <% if flash[:notice].present? %>
        <div class="bito-flash notice"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert].present? %>
        <div class="bito-flash alert"><%= flash[:alert] %></div>
      <% end %>

      <%= yield %>
    </div>
  </body>
</html>
