<!DOCTYPE html>
<html lang="pt-BR" data-theme="dark">
  <head>
    <title><%= content_for(:title).presence || "bitolando" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:description).presence || "caderno público de engenharia e arquitetura de software" %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" type="image/x-icon"    href="/layout/assets/img/favicon_io/favicon.ico">
    <link rel="icon" type="image/png" sizes="16x16" href="/layout/assets/img/favicon_io/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/layout/assets/img/favicon_io/favicon-32x32.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/layout/assets/img/favicon_io/apple-touch-icon.png">
    <link rel="manifest" href="/layout/assets/img/favicon_io/site.webmanifest">
    <meta name="theme-color" content="#080808">
    <%= render "shared/theme_bootstrap" %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <div class="bito">
      <% if flash[:notice].present? %>
        <div class="bito-flash notice"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert].present? %>
        <div class="bito-flash alert"><%= flash[:alert] %></div>
      <% end %>
      <%= yield %>
    </div>
  </body>
</html>
