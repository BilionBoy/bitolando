<header class="bito-header">
  <%= link_to root_path, class: "bito-logo", "aria-label": "bitolando" do %>
    <span class="bito-logo-mark" aria-hidden="true">
      <img class="bito-logo-img bito-logo-img-light" src="/layout/assets/img/bitolando-symbol-light.png" alt="" width="36" height="36">
      <img class="bito-logo-img bito-logo-img-dark"  src="/layout/assets/img/bitolando-symbol-dark.png"  alt="" width="36" height="36">
    </span>
    <span class="bito-logo-text">bitolando</span>
  <% end %>
  <nav class="bito-meta-nav">
    <%= link_to "blog", root_path, class: (active_nav == :blog ? "active" : nil) %>
    <span class="sep">·</span>
    <%= link_to "sobre", sobre_path, class: (active_nav == :sobre ? "active" : nil) %>
    <span class="sep">·</span>
    <%= link_to "rss", rss_feed_path(format: :xml) %>
    <span class="sep">·</span>
    <button class="bito-theme-toggle" onclick="bitoToggleTheme()" title="alternar tema" aria-label="alternar tema claro/escuro">◐</button>
    <% if usuario_signed_in? %>
      <span class="sep">·</span>
      <%= link_to "⚙", admin_root_path, title: "admin", style: "font-size:15px;padding:6px 8px;margin:-6px -4px;" %>
    <% end %>
  </nav>
</header>

<script>
  function bitoToggleTheme() {
    var html = document.documentElement;
    var next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('bito-theme', next);
  }
</script>
