<main class="bito-admin-main">
  <div class="bito-admin-bread">
    <%= link_to "posts", admin_posts_path %>
    <span class="sep">/</span>
    <span class="here">#<%= format("%03d", @post.id) %> · editar</span>
  </div>

  <div class="bito-admin-pagehead">
    <div>
      <h1>editar entrada</h1>
      <div class="meta" style="margin-top:8px;"><%= @post.status.nome %></div>
    </div>
    <div class="bito-admin-actions">
      <%= link_to "biblioteca de imagens →", admin_imagens_path, target: "_blank", class: "bito-btn ghost" %>
      <% if @post.publicado? %>
        <%= link_to "ver no site →", post_path(@post.slug), target: "_blank", class: "bito-btn ghost" %>
      <% end %>
      <%= link_to "excluir", admin_post_path(@post),
          data: { turbo_method: :delete, turbo_confirm: "Excluir este post?" },
          class: "bito-btn danger" %>
    </div>
  </div>

  <%= render "form", post: @post %>
</main>
