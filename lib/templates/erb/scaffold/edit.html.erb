<%# frozen_string_literal: true %>
<main class="bito-admin-main">
  <div class="bito-admin-bread">
    <%%= link_to t("activerecord.models.<%= singular_table_name %>.other"), <%= plural_table_name %>_path %>
    <span class="sep">/</span>
    <span class="here">editar #<%%= @<%= singular_table_name %>.id %></span>
  </div>

  <div class="bito-admin-pagehead">
    <h1>Editar <%%= t("activerecord.models.<%= singular_table_name %>.one") %></h1>
    <div class="bito-admin-actions">
      <%%= link_to "excluir", <%= singular_table_name %>_path(@<%= singular_table_name %>),
          data: { turbo_method: :delete, turbo_confirm: "Excluir?" },
          class: "bito-btn danger" %>
    </div>
  </div>

  <%%= render "form", <%= singular_table_name %>: @<%= singular_table_name %> %>
</main>
